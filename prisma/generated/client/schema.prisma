generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String           @id @default(uuid())
  name            String
  sku             String?
  categoryId      String?
  basePrice       Int
  trackInventory  Boolean          @default(true)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stock           InventoryStock?
  sizes           ProductSize[]
  variationGroups VariationGroup[]
  orderItems      OrderItem[]

  @@index([categoryId])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model InventoryStock {
  id        String  @id @default(uuid())
  productId String  @unique
  qty       Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSize {
  id         String  @id @default(uuid())
  productId  String
  name       String
  priceDelta Int
  sortOrder  Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model VariationGroup {
  id            String            @id @default(uuid())
  productId     String
  name          String
  minSelectable Int               @default(0)
  maxSelectable Int               @default(1)
  required      Boolean           @default(false)
  sortOrder     Int               @default(0)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  choices       VariationChoice[]
}

model VariationChoice {
  id         String         @id @default(uuid())
  groupId    String
  name       String
  priceDelta Int
  sortOrder  Int            @default(0)
  group      VariationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(uuid())
  orderNumber Int         @unique
  subtotal    Int
  discount    Int
  fees        Int
  tax         Int
  total       Int
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@index([createdAt])
}

model OrderItem {
  id            String               @id @default(uuid())
  orderId       String
  productId     String
  productName   String
  sizeName      String?
  unitBasePrice Int
  quantity      Int
  lineTotal     Int
  order         Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variations    OrderItemVariation[]
}

model OrderItemVariation {
  id          String    @id @default(uuid())
  orderItemId String
  groupName   String
  choiceName  String
  priceDelta  Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id        Int    @id
  storeName String
}
